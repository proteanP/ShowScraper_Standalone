#!/usr/bin/env ruby

require 'date'
current_time = DateTime.now
cdt = current_time.strftime "%m/%d/%Y %H:%M"
puts "Current Date and Time: "+cdt

require 'optparse'
require "#{__dir__}/../scraper/scraper.rb"

ENV["HEADLESS"] ||= "true"

opts = {}
OptionParser.new do |opt|
  opt.on('--headless HEADLESS') { |val| ENV["HEADLESS"] = val }
  opt.on('--limit LIMIT') { |val| opts[:limit] = val.to_i }
  opt.on('--skip-persist') { opts[:skip_persist] = true }
  opt.on('--rescue BOOL') { |val| ENV["RESCUE_SCRAPING_ERRORS"] = val }
  opt.on('--no-scrape') { ENV["ONLY_UPDATE_VENUES"] = "true" }
  opt.on('--debugger') { ENV["DEBUGGER"] = "true" }
  opt.on('--sources SOURCES') do |val|
    opts[:sources] = val.split(",").map do |source|
      source.constantize
    rescue
      puts "ERROR: unknown source \"#{source}\""
      exit!
    end
  end
end.parse!

# Dry runs must never reset or append to the production GCS scraper log.
# A caller can still set LOG_PATH to capture dry-run output locally.
if opts[:skip_persist]
  ENV["LOG_GCS_PATH"] = ""
  ENV["LOG_PATH"] = ENV.fetch(
    "DRY_RUN_LOG_PATH",
    File.expand_path("../tmp/dry_run.log", __dir__)
  )
end

puts "SOURCES: #{opts[:sources]}"

Utils.reset_logs!

results, errors = Scraper.run(
  opts[:sources],
  events_limit: opts[:limit],
  persist_mode: opts[:skip_persist] ? nil : :static
)

puts "done\n"

warnings = []
ignore_empty_warning_sources = %w[
  Zeitgeist
  BandcampOakland
  ManuallyAdded
]

results.each do |source, events|
  if events.count == 0 && !ignore_empty_warning_sources.include?(source)
    warnings << source
  end
end

warnings.each do |source|
  puts "WARNING: #{source} produced 0 events!"
end

errors.each do |error|
  puts "ERROR: #{error[:source]} failed to scrape. Skipped."
end

log_lines = []
if opts[:skip_persist]
  results.each do |source, events|
    log_lines << "#{Time.now.strftime("%m/%d/%Y")}: DRY RUN: scraped #{events.uniq.count.to_s.ljust(4)} events from #{source}"
  end
end
warnings.each do |source|
  log_lines << "#{Time.now.strftime("%m/%d/%Y")}: WARNING: #{source} produced no events"
end
errors.each do |error|
  log_lines << "#{Time.now.strftime("%m/%d/%Y")}: ERROR: #{error[:source]} failed to scrape"
end
Utils.append_log_lines(log_lines)
